{
  "name": "@jsonstudio/llms",
  "version": "0.2.11",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./conversion": {
      "import": "./dist/conversion/index.js",
      "types": "./dist/conversion/index.d.ts"
    },
    "./conversion/switch-orchestrator": {
      "import": "./dist/conversion/switch-orchestrator.js",
      "types": "./dist/conversion/switch-orchestrator.d.ts"
    },
    "./v2/guidance": {
      "import": "./dist/guidance/index.js",
      "types": "./dist/guidance/index.d.ts"
    },
    "./v2/*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./guidance": {
      "import": "./dist/guidance/index.js",
      "types": "./dist/guidance/index.d.ts"
    }
  }
}
"tiktoken": "^1.0.22"

{
  "id": "chat:deepseek-web",
  "protocol": "openai-chat",
  "request": {
    "mappings": [
      {
        "action": "snapshot",
        "phase": "compat-pre"
      },
      {
        "action": "tool_text_request_guidance",
        "config": {
          "marker": "Tool-call output contract (STRICT)",
          "includeToolNames": true,
          "requireTools": true
        }
      },
      {
        "action": "deepseek_web_request"
      },
      {
        "action": "snapshot",
        "phase": "compat-post"
      }
    ]
  },
  "response": {
    "mappings": [
      {
        "action": "snapshot",
        "phase": "compat-pre"
      },
      {
        "action": "deepseek_web_response",
        "config": {
          "textNormalizer": {
            "jsonToolRepair": {
              "toolNameAliases": {
                "shell_command": "exec_command",
                "shell": "exec_command",
                "bash": "exec_command",
                "terminal": "exec_command"
              },
              "argumentAliases": {
                "exec_command": {
                  "workdir": [
                    "workdir",
                    "cwd",
                    "input.cwd"
                  ]
                }
              }
            }
          }
        }
      },
      {
        "action": "snapshot",
        "phase": "compat-post"
      }
    ]
  },
  "policyOverrides": {
    "observe": {
      "skip": true
    },
    "enforce": {
      "skip": true
    }
  },
  "sdkBinding": {
    "family": "custom-runtime",
    "supported": false,
    "notes": "Web-account text-tool providers require the existing RouteCodex runtime path."
  }
}

{
  "version": "2.0.0",
  "providerId": "my-openai",
  "provider": {
    "id": "my-openai",
    "enabled": true,
    "type": "openai",
    "baseURL": "https://api.example.com/v1",
    "auth": {
      "type": "apikey",
      "apiKey": "${MY_OPENAI_API_KEY}"
    },
    "defaultModel": "gpt-4.1-mini",
    "models": {
      "gpt-4.1-mini": {
        "supportsStreaming": true
      }
    }
  }
}
